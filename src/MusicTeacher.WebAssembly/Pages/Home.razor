@page "/"
@using MusicTeacher.Shared.Lessons
@using MusicTeacher.Shared.MusicTheory
@using MusicTeacher.Shared.Progress
@inject HttpClient Http
@inject IProgressStore ProgressStore
@inject MusicAudioService Audio
@inject AppLocalizer Localizer
@inject IJSRuntime JS

<PageTitle>@Localizer["AppTitle"]</PageTitle>

@if (!hasStarted)
{
    <section class="start-screen">
        <div class="start-card">
            <div class="lesson-kicker">@(lesson is null ? string.Empty : Localizer["TrebleClefKicker"])</div>
            <h1>@Localizer["StartScreenTitle"]</h1>
            <p>@Localizer["StartScreenIntro"]</p>

            <div class="start-section">
                <span>@Localizer["LanguageSelectorLabel"]</span>
                <div class="language-switcher" role="group" aria-label="@Localizer["LanguageSelectorLabel"]">
                    @foreach (var culture in AppLocalizer.SupportedCultures)
                    {
                        <button class="@GetCultureClass(culture.Name)"
                                type="button"
                                @onclick="() => ChangeCulture(culture.Name)">
                            @Localizer.GetCultureDisplayName(culture)
                        </button>
                    }
                </div>
            </div>

            <div class="start-options" aria-label="@Localizer["PracticeModeLabel"]">
                <button class="start-option-card"
                        type="button"
                        @onclick="() => StartPractice(PracticeMode.FreeExplore)">
                    <strong>@Localizer["FreeExploreMode"]</strong>
                    <small>@Localizer["FreeExploreDescription"]</small>
                </button>
                <button class="start-option-card is-primary"
                        type="button"
                        @onclick="() => StartPractice(PracticeMode.LearningPath)">
                    <strong>@Localizer["LearningMode"]</strong>
                    <small>@Localizer["LearningModeDescription"]</small>
                </button>
            </div>
        </div>
    </section>
}
else
{
    <section class="practice-stage">
        <div class="lesson-panel">
            <div class="lesson-kicker">@(lesson is null ? string.Empty : Localizer["TrebleClefKicker"])</div>
            <h1>@Localizer["TrebleClefStartTitle"]</h1>

            <button class="back-to-start-button" type="button" @onclick="ReturnToStart">
                @Localizer["BackToStart"]
            </button>

            <div class="mode-switch" role="tablist" aria-label="@Localizer["DrillModeLabel"]">
                <button class="@GetModeClass(DrillMode.NameNote)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.NameNote)"
                        @onclick="() => SetMode(DrillMode.NameNote)">
                    @Localizer["NameMode"]
                </button>
                <button class="@GetModeClass(DrillMode.PlaceNote)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.PlaceNote)"
                        @onclick="() => SetMode(DrillMode.PlaceNote)">
                    @Localizer["PlaceMode"]
                </button>
                <button class="@GetModeClass(DrillMode.HearNotePlay)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.HearNotePlay)"
                        @onclick="() => SetMode(DrillMode.HearNotePlay)">
                    @Localizer["HearPlayMode"]
                </button>
                <button class="@GetModeClass(DrillMode.HearNotePlace)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.HearNotePlace)"
                        @onclick="() => SetMode(DrillMode.HearNotePlace)">
                    @Localizer["HearPlaceMode"]
                </button>
            </div>

            @if (practiceMode == PracticeMode.LearningPath)
            {
                <div class="level-card" aria-live="polite">
                    <div class="level-card-header">
                        <span>@Localizer.Format("LearningLevelLabel", CurrentLevelNumber)</span>
                        <button class="reset-progress-button" type="button" @onclick="ResetProgress">
                            @Localizer["ResetProgress"]
                        </button>
                    </div>
                    <strong>@CurrentDrillTitle</strong>
                    <small>@LearningGoalText</small>
                </div>
            }

            <div class="score-strip" aria-live="polite">
                <span>@Localizer.Format("ScoreCorrect", DisplayCorrectAnswers)</span>
                <span>@Localizer.Format("ScoreTries", DisplayAttempts)</span>
                <span>@Localizer.Format("ScoreStreak", DisplayStreak)</span>
            </div>
        </div>

        <div class="exercise-board">
            <div class="prompt-row">
                <div>
                    <p class="prompt-label">@CurrentDrillTitle</p>
                    <h2>@PromptText</h2>
                </div>
                <div class="prompt-actions">
                    @if (IsHearingMode)
                    {
                        <button class="listen-button" type="button" @onclick="PlayAssignmentNote" aria-label="@Localizer["PlayAssignmentNote"]">
                            @Localizer["PlayAssignmentNote"]
                        </button>
                    }
                    <button class="next-button" type="button" @onclick="AdvanceRound" aria-label="@Localizer["NextNote"]">@Localizer["Next"]</button>
                </div>
            </div>

            @if (ShowsStaff)
            {
                <MusicStaff DisplayedPitch="@DisplayedPitch"
                            IsPlacementMode="@IsPlacementMode"
                            SelectableSteps="@selectableSteps"
                            SelectedStep="@selectedStep"
                            OnStepPreviewed="PreviewStaffStep"
                            OnStepSelected="SelectStaffStep" />
            }

            @if (ShowsAccidentalSelector)
            {
                <div class="accidental-selector" role="group" aria-label="@Localizer["AccidentalSelectorLabel"]">
                    <span>@Localizer["AccidentalSelectorLabel"]</span>
                    <button class="accidental-button" type="button" disabled aria-label="@Localizer["AccidentalFlat"]">♭</button>
                    <button class="accidental-button is-active" type="button" disabled aria-label="@Localizer["AccidentalNatural"]">♮</button>
                    <button class="accidental-button" type="button" disabled aria-label="@Localizer["AccidentalSharp"]">♯</button>
                    <small>@Localizer["AccidentalSelectorDisabledHint"]</small>
                </div>
            }

            @if (ShowsKeyboard)
            {
                <PianoKeyboard Pitches="@CurrentNotes"
                               HighlightedPitch="@KeyboardHighlightedPitch"
                               OnPitchPreviewed="PreviewPitch"
                               OnPitchSelected="SelectKeyboardPitch" />
            }

            <div class="@feedbackClass" aria-live="polite">@FeedbackText</div>
        </div>
    </section>
}
