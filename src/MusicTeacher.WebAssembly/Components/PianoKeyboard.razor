@using MusicTeacher.Shared.MusicTheory
@inject AppLocalizer Localizer

<div class="piano-keyboard" role="group" aria-label="@Localizer["KeyboardAriaLabel"]">
    <div class="white-key-row">
        @foreach (var pitch in Pitches)
        {
            var keyClass = HighlightedPitch == pitch ? "piano-white-key is-highlighted" : "piano-white-key";

            <button type="button"
                    class="@keyClass"
                    data-pitch="@pitch.ScientificName"
                    aria-label="@GetPitchLabel(pitch)"
                    @onpointerenter="() => PreviewPitch(pitch)"
                    @onclick="() => SelectPitch(pitch)">
            </button>
        }
    </div>

    <div class="black-key-row">
        @foreach (var key in BlackKeys)
        {
            <button type="button"
                    class="@GetBlackKeyClass(key)"
                    data-pitch="@key.SharpPitch.ScientificName"
                    aria-label="@GetBlackKeyLabel(key)"
                    style="@GetBlackKeyStyle(key.WhiteKeyIndex)"
                    @onpointerenter="() => PreviewPitch(key.SharpPitch)"
                    @onclick="() => SelectPitch(key.SharpPitch)">
                <span>@key.SharpPitch.FixedDoName</span>
                <span>@key.FlatPitch.FixedDoName</span>
                <small>@key.SharpPitch.DisplayName / @key.FlatPitch.DisplayName</small>
            </button>
        }
    </div>

    <div class="key-label-row" aria-hidden="true">
        @foreach (var pitch in Pitches)
        {
            <span class="key-label">
                <span>@pitch.FixedDoName</span>
                <small>@pitch.ScientificName.ToLowerInvariant()</small>
            </span>
        }
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<Pitch> Pitches { get; set; } = [];

    [Parameter]
    public Pitch? HighlightedPitch { get; set; }

    [Parameter]
    public EventCallback<Pitch> OnPitchPreviewed { get; set; }

    [Parameter]
    public EventCallback<Pitch> OnPitchSelected { get; set; }

    private IReadOnlyList<BlackPianoKey> BlackKeys => Pitches
        .Select((pitch, index) => new { pitch, index })
        .Where(item => HasBlackKeyAfter(item.pitch))
        .Select(item => new BlackPianoKey(
            item.index,
            new Pitch(item.pitch.Letter, item.pitch.Octave, Accidental.Sharp),
            GetFlatPitchAfter(item.pitch)))
        .ToArray();

    private async Task PreviewPitch(Pitch pitch) => await OnPitchPreviewed.InvokeAsync(pitch);

    private async Task SelectPitch(Pitch pitch) => await OnPitchSelected.InvokeAsync(pitch);

    private static string GetPitchLabel(Pitch pitch) => $"{pitch.FixedDoName} {pitch.ScientificName}";

    private string GetBlackKeyClass(BlackPianoKey key)
        => HighlightedPitch == key.SharpPitch || HighlightedPitch == key.FlatPitch
            ? "piano-black-key is-highlighted"
            : "piano-black-key";

    private static string GetBlackKeyLabel(BlackPianoKey key)
        => $"{key.SharpPitch.FixedDoName} {key.SharpPitch.DisplayName}, {key.FlatPitch.FixedDoName} {key.FlatPitch.DisplayName}";

    private string GetBlackKeyStyle(int whiteKeyIndex)
    {
        var keyCount = Math.Max(Pitches.Count, 1);
        var left = ((whiteKeyIndex + 1d) / keyCount) * 100d;

        return FormattableString.Invariant($"left: calc({left:0.###}% - var(--black-key-width) / 2);");
    }

    private static bool HasBlackKeyAfter(Pitch pitch)
        => pitch.Accidental == Accidental.Natural && pitch.Letter is NoteLetter.C or NoteLetter.D or NoteLetter.F or NoteLetter.G or NoteLetter.A;

    private static Pitch GetFlatPitchAfter(Pitch pitch)
        => pitch.Letter switch
        {
            NoteLetter.C => new Pitch(NoteLetter.D, pitch.Octave, Accidental.Flat),
            NoteLetter.D => new Pitch(NoteLetter.E, pitch.Octave, Accidental.Flat),
            NoteLetter.F => new Pitch(NoteLetter.G, pitch.Octave, Accidental.Flat),
            NoteLetter.G => new Pitch(NoteLetter.A, pitch.Octave, Accidental.Flat),
            NoteLetter.A => new Pitch(NoteLetter.B, pitch.Octave, Accidental.Flat),
            _ => throw new ArgumentOutOfRangeException(nameof(pitch), pitch, null)
        };

    private sealed record BlackPianoKey(int WhiteKeyIndex, Pitch SharpPitch, Pitch FlatPitch);
}
